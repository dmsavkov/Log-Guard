# Artifact storage root (default: ~/.logguard/<id>/)
# LOGGUARD_HOME=

# Live Gemini distillation on MEDIUM/FULL logs (required when USE_LLM_SUMMARIZATION=true)
GOOGLE_API_KEY=

# LLM summarization on FULL route (default: true). Set false to skip Gemini (like --dry-run).
# USE_LLM_SUMMARIZATION=true

# Set to 1 to show pipeline debug logs on stderr
# LOGGUARD_VERBOSE=
